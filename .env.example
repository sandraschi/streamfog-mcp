# Streamfog MCP configuration
# Copy this to .env and fill in your values

# Streamer.bot WebSocket connection
STREAMFOG_MCP_STREAMERBOT_HOST=127.0.0.1
STREAMFOG_MCP_STREAMERBOT_PORT=8080
STREAMFOG_MCP_STREAMERBOT_TOKEN=

# Lens map file path
STREAMFOG_MCP_LENS_MAP_PATH=lenses.json

# Server port
STREAMFOG_MCP_PORT=10994
STREAMFOG_MCP_LOG_LEVEL=INFO
